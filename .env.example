# --- LLM (required) ---
ANTHROPIC_API_KEY=sk-ant-...
# Model used across both projects.
CLAUDE_MODEL=claude-opus-4-8

# --- Embeddings (rag/) ---
# If VOYAGE_API_KEY is set, Voyage `voyage-3` is used (1024-dim).
# If unset, falls back to a local sentence-transformers model (384-dim).
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3
LOCAL_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Embedding dimension. Must match the embedder:
#   voyage-3 -> 1024 ; all-MiniLM-L6-v2 -> 384
EMBED_DIM=1024

# --- Vector store (rag/) ---
# Postgres with the pgvector extension installed.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag

# --- Agent (agent/) ---
# Root the file/shell tools are confined to. Defaults to the repo root.
AGENT_WORKDIR=.
# Set to 1 to auto-approve write/bash tools (skip the confirmation prompt).
AGENT_AUTO_APPROVE=0
